# ===== Shopify =====
# 从 dev store 后台 → Apps → Develop apps → Admin API access token 获取
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2025-10

# ===== 模型 API Keys =====
# 实测主力：阿里 DashScope (qwen-plus) + 智谱 (glm-5) 双 provider 互为 fallback
# 至少配一个 DashScope 就能跑；Anthropic/OpenAI 未实测（可选）
DASHSCOPE_API_KEY=sk-xxxx      # 阿里百炼 https://dashscope.console.aliyun.com
ZHIPU_API_KEY=your-zhipu-key   # 智谱 https://open.bigmodel.cn（作为 fallback）
ANTHROPIC_API_KEY=sk-ant-xxxx  # 可选，当前 llm_router.yaml 未启用
OPENAI_API_KEY=sk-xxxx         # 可选，当前 llm_router.yaml 未启用

# ===== 数据库 =====
# docker-compose 默认映射到本地 5433
DATABASE_URL=postgresql://sidekick:sidekick@localhost:5433/sidekick

# ===== Redis =====
# docker-compose 默认映射到本地 6380
REDIS_URL=redis://localhost:6380/0

# ===== Qdrant（语义缓存向量库）=====
QDRANT_URL=http://localhost:6333

# ===== Langfuse（自托管观测）=====
LANGFUSE_HOST=http://localhost:3030
LANGFUSE_PUBLIC_KEY=pk-lf-xxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxx
LANGFUSE_NEXTAUTH_SECRET=please-generate-a-random-32-char-string
LANGFUSE_SALT=please-generate-a-random-salt

# ===== HuggingFace（sentence-transformers 模型源）=====
# 国内网络请开镜像，否则 semantic cache 会因下载不到 embedder 而降级
HF_ENDPOINT=https://hf-mirror.com

# ===== App 行为 =====
SIDEKICK_ENV=development
SIDEKICK_LOG_LEVEL=INFO
# 注意：agent.max_iterations 实际由 config/llm_router.yaml 读取（当前 8）
# 这里的值仅作为 fallback default

# ===== 默认模型（用于 CLI / 单元测试）=====
# 真正的 Agent 路由由 config/llm_router.yaml 控制，这个变量只用于 CLI fallback
DEFAULT_MODEL=dashscope:qwen-plus
