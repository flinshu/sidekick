# ===== Shopify =====
# 从 dev store 后台 → Apps → Develop apps → Admin API access token 获取
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2025-10

# ===== 模型 API Keys =====
# 至少填一个；M1 推荐至少有 Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxx
OPENAI_API_KEY=sk-xxxx
# 阿里百炼 (Qwen) - https://dashscope.console.aliyun.com
DASHSCOPE_API_KEY=sk-xxxx

# ===== 数据库 =====
# docker-compose 默认映射到本地 5433
DATABASE_URL=postgresql://sidekick:sidekick@localhost:5433/sidekick

# ===== Redis =====
# docker-compose 默认映射到本地 6380
REDIS_URL=redis://localhost:6380/0

# ===== Qdrant =====
QDRANT_URL=http://localhost:6333

# ===== Langfuse =====
LANGFUSE_HOST=http://localhost:3030
LANGFUSE_PUBLIC_KEY=pk-lf-xxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxx
LANGFUSE_NEXTAUTH_SECRET=please-generate-a-random-32-char-string
LANGFUSE_SALT=please-generate-a-random-salt

# ===== App 行为 =====
SIDEKICK_ENV=development
SIDEKICK_LOG_LEVEL=INFO
AGENT_MAX_ITERATIONS=10

# ===== M1 默认模型 =====
DEFAULT_MODEL=claude-sonnet-4-6
